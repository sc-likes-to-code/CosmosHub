# ── API Keys ──
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── Server Config ──
PORT=3001
VITE_API_URL=http://localhost:3001

# ── Feed Volume (Optional) ──
# Max feed items fetched per source
VITE_RSS_MAX_PER_SOURCE=20
# Max cards shown in UI after ranking/dedupe
VITE_MAX_CARDS=120
# Number of cards that receive paid AI summaries (rest use local fallback summary)
VITE_AI_SUMMARY_LIMIT=40

# ── Frontend Environment ──
# This will be available as import.meta.env.VITE_ANTHROPIC_API_KEY
VITE_ANTHROPIC_API_KEY=sk-ant-your-api-key-here
